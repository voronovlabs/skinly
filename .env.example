# =============================================================================
# Skinly — environment template
# Скопируй в .env и заполни значениями для локальной разработки.
# =============================================================================

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- PostgreSQL (используется docker-compose и Prisma) ---
POSTGRES_USER=skinly
POSTGRES_PASSWORD=skinly
POSTGRES_DB=skinly

# Prisma подключается локально по этому URL
DATABASE_URL=postgresql://skinly:skinly@localhost:5432/skinly?schema=public

# --- Auth (Phase 4) ---
# ОБЯЗАТЕЛЬНО для подписи сессионных JWT. Сгенерировать:
#   openssl rand -base64 32
# Если не задан — используется небезопасный dev-fallback (валится в production).
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# --- Feature flags ---
# AI-объяснения через Anthropic API. По умолчанию выключено — MVP работает на rule-based шаблонах.
FEATURE_AI_EXPLANATION=false
ANTHROPIC_API_KEY=

# Open Beauty Facts как fallback при отсутствии товара в локальной БД.
# Если выключено — приложение работает только на seed-данных.
FEATURE_OPENBEAUTYFACTS=false
